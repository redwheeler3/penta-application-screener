{
  "permissions": {
    "allow": [
      "Bash(uv run pytest *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(./.venv/bin/python -m pytest *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-db.sh\""
          }
        ]
      }
    ]
  }
}
